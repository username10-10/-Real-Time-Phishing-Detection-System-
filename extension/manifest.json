{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "2.0",
  "description": "Real-time phishing URL detection using Machine Learning and XAI",
  
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}